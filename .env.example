# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=VPN Dashboard
APP_VERSION=0.1.0

# ── Web server ────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
HTTPS_PORT=443
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Admin credentials (used for JWT auth) ────────────────────────────────────
WEB_SUPERADMIN_USERNAME=admin
WEB_SUPERADMIN_PASSWORD=change_me_please

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_IDS=[123456789]

# long = long polling (для разработки)
# webhook = вебхук (для продакшена / ngrok)
TELEGRAM_TYPE_PROTOCOL=long

# Только для webhook режима.
# Бот и панель работают на ОДНОМ порту (SERVER_PORT).
# Nginx/ngrok проксирует HTTPS → http://127.0.0.1:8000
#
# Для ngrok:
#   ngrok http 8000
#   TELEGRAM_WEBHOOK_URL=https://<id>.ngrok-free.app/webhook/bot
#
# Для продакшена:
#   TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/bot
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/bot
TELEGRAM_WEBHOOK_PATH=/webhook/bot

# ── Pasarguard VPN panel ──────────────────────────────────────────────────────
PASARGUARD_ADMIN_PANEL=https://your-panel.example.com:8012
PASARGUARD_ADMIN_LOGIN=admin
PASARGUARD_ADMIN_PASSWORD=your_password
PASARGUARD_API_KEY=your_api_key_here

# ── Yookassa ──────────────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=1234567
YOOKASSA_SECRET_KEY=test_your_secret_key

# ── Database ──────────────────────────────────────────────────────────────────
DB_ENGINE=postgresql
DB_NAME=vpnbot
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_PATH=logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_LEVEL=INFO
