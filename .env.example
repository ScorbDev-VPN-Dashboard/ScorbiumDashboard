# =============================================================================
#  VPN Dashboard — Environment Configuration
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Scorbium Dashboard VPN
APP_VERSION=1.6.1
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ALLOWED_ORIGINS=["https://your-domain.com"]

# ── Security ──────────────────────────────────────────────────────────────────
# Dedicated JWT signing secret (auto-generated by setup.sh).
# IMPORTANT: Changing this will invalidate all active admin sessions!
JWT_SECRET_KEY=

# Legacy fallback: superadmin credentials (used for first login + DB seeding)
WEB_SUPERADMIN_USERNAME=admin
WEB_SUPERADMIN_PASSWORD=changeme

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_ADMIN_IDS=[123456789]
TELEGRAM_TYPE_PROTOCOL=webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/bot
TELEGRAM_WEBHOOK_PATH=/webhook/bot

# ── VPN Panel (Marzban / Pasarguard) ──────────────────────────────────────────
PASARGUARD_ADMIN_PANEL=https://panel.example.com:8012
PASARGUARD_ADMIN_LOGIN=admin
PASARGUARD_ADMIN_PASSWORD=changeme
PASARGUARD_API_KEY=
VPN_PANEL_TYPE=marzban

# ── Database ──────────────────────────────────────────────────────────────────
DB_ENGINE=postgresql
DB_NAME=vpnbot
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# ── Domain / SSL ──────────────────────────────────────────────────────────────
HTTPS_PORT=443
DOMAIN=your-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_PATH=logs
LOG_ROTATION=1 day
LOG_RETENTION=30 days
LOG_LEVEL=INFO

